{
  "uid": "fcsc-vm-detail",
  "title": "FCSC VM Detail",
  "description": "Deep dive into a single VM: all queue metrics, connectivity, and logs",
  "tags": ["fcsc", "vm"],
  "timezone": "utc",
  "editable": true,
  "refresh": "5s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "vm",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
        "query": "label_values(fcsc_bot_info, vm)",
        "refresh": 2,
        "sort": 1,
        "current": {},
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "VM: $vm",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Bot Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [
        {
          "expr": "fcsc_bot_running{vm=\"$vm\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "RUNNING", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 3,
      "title": "Git Branch",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [
        {
          "expr": "fcsc_bot_info{vm=\"$vm\"}",
          "legendFormat": "{{ git_branch }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "name"
      }
    },
    {
      "id": 4,
      "title": "RPC",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [
        {
          "expr": "fcsc_rpc_up{vm=\"$vm\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "red" }, { "value": 1, "color": "green" }]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 5,
      "title": "ClickHouse",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [
        {
          "expr": "fcsc_clickhouse_up{vm=\"$vm\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "red" }, { "value": 1, "color": "green" }]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 6,
      "title": "Geyser Recv Rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [
        {
          "expr": "fcsc_geyser_recv_rate{vm=\"$vm\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "msg/s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 7,
      "title": "Log Age",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [
        {
          "expr": "time() - fcsc_log_last_line_timestamp{vm=\"$vm\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 30, "color": "yellow" },
              { "value": 120, "color": "red" }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 10,
      "title": "Geyser Subscribe",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 11,
      "title": "Geyser Receive Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [
        {
          "expr": "fcsc_geyser_recv_rate{vm=\"$vm\"}",
          "legendFormat": "Recv Rate",
          "refId": "A"
        },
        {
          "expr": "fcsc_geyser_send_rate{vm=\"$vm\"}",
          "legendFormat": "Send Rate",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "msg/s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "pointSize": 5,
            "showPoints": "auto"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 12,
      "title": "Geyser Backlog",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [
        {
          "expr": "fcsc_geyser_backlog{vm=\"$vm\"}",
          "legendFormat": "Backlog",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineInterpolation": "smooth"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 100, "color": "yellow" },
              { "value": 1000, "color": "red" }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 13,
      "title": "Geyser Total In/Out",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [
        {
          "expr": "fcsc_geyser_total_in{vm=\"$vm\"}",
          "legendFormat": "Total In",
          "refId": "A"
        },
        {
          "expr": "fcsc_geyser_total_out{vm=\"$vm\"}",
          "legendFormat": "Total Out",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineInterpolation": "smooth"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 20,
      "title": "Queue Metrics",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "id": 21,
      "title": "Queue Send Rates",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [
        {
          "expr": "fcsc_queue_send_rate{vm=\"$vm\"}",
          "legendFormat": "{{ queue }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "msg/s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 22,
      "title": "Queue Receive Rates",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [
        {
          "expr": "fcsc_queue_recv_rate{vm=\"$vm\"}",
          "legendFormat": "{{ queue }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "msg/s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth"
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 23,
      "title": "Queue Backlogs",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "DS_PROMETHEUS" },
      "targets": [
        {
          "expr": "fcsc_queue_backlog{vm=\"$vm\"}",
          "legendFormat": "{{ queue }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 50, "color": "yellow" },
              { "value": 500, "color": "red" }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 30,
      "title": "Logs",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false
    },
    {
      "id": 31,
      "title": "Recent Logs",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "loki", "uid": "DS_LOKI" },
      "targets": [
        {
          "expr": "{vm=\"$vm\", job=\"arb-bot\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
