{
  "uid": "fcsc-log-explorer",
  "title": "FCSC Log Explorer",
  "description": "Search and browse bot logs across all VMs. Designed for both technical and non-technical users.",
  "tags": ["fcsc", "logs"],
  "timezone": "utc",
  "editable": true,
  "refresh": "",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "vm",
        "label": "VM",
        "type": "query",
        "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
        "query": "label_values({job=\"arb-bot\"}, vm)",
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "level",
        "label": "Log Level",
        "type": "custom",
        "query": "INFO,WARN,ERROR,DEBUG,TRACE",
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "search",
        "label": "Search",
        "type": "textbox",
        "current": {
          "value": ""
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Log Volume by VM",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum by (vm) (count_over_time({job=\"arb-bot\", vm=~\"$vm\"} [1m]))",
          "legendFormat": "{{ vm }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "stacking": { "mode": "normal" }
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 2,
      "title": "Error & Warning Rate",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum by (vm) (count_over_time({job=\"arb-bot\", vm=~\"$vm\"} |~ \"ERROR|WARN\" [1m]))",
          "legendFormat": "{{ vm }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60
          },
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 10,
      "title": "Log Stream",
      "type": "logs",
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{job=\"arb-bot\", vm=~\"$vm\"} |~ \"(?i)$level\" |~ \"(?i)$search\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "id": 20,
      "title": "Quick Searches",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "collapsed": true,
      "panels": [
        {
          "id": 21,
          "title": "Arb Executions",
          "type": "logs",
          "gridPos": { "h": 10, "w": 24, "x": 0, "y": 33 },
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "targets": [
            {
              "expr": "{job=\"arb-bot\", vm=~\"$vm\"} |~ \"(?i)(arb.*execut|sent_arb|landed_arb|profit)\"",
              "refId": "A"
            }
          ],
          "options": {
            "showTime": true,
            "showLabels": true,
            "wrapLogMessage": true,
            "enableLogDetails": true,
            "sortOrder": "Descending"
          }
        },
        {
          "id": 22,
          "title": "Geyser Events",
          "type": "logs",
          "gridPos": { "h": 10, "w": 24, "x": 0, "y": 43 },
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "targets": [
            {
              "expr": "{job=\"arb-bot\", vm=~\"$vm\"} |~ \"(?i)(geyser|QUEUE.*geyser)\"",
              "refId": "A"
            }
          ],
          "options": {
            "showTime": true,
            "showLabels": true,
            "wrapLogMessage": true,
            "enableLogDetails": true,
            "sortOrder": "Descending"
          }
        },
        {
          "id": 23,
          "title": "Errors Only",
          "type": "logs",
          "gridPos": { "h": 10, "w": 24, "x": 0, "y": 53 },
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "targets": [
            {
              "expr": "{job=\"arb-bot\", vm=~\"$vm\"} |~ \"ERROR\"",
              "refId": "A"
            }
          ],
          "options": {
            "showTime": true,
            "showLabels": true,
            "wrapLogMessage": true,
            "enableLogDetails": true,
            "sortOrder": "Descending"
          }
        },
        {
          "id": 24,
          "title": "Pool Loading",
          "type": "logs",
          "gridPos": { "h": 10, "w": 24, "x": 0, "y": 63 },
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "targets": [
            {
              "expr": "{job=\"arb-bot\", vm=~\"$vm\"} |~ \"(?i)(pool.*load|pool.*reload|TITAN RELOAD|Finished pool loading)\"",
              "refId": "A"
            }
          ],
          "options": {
            "showTime": true,
            "showLabels": true,
            "wrapLogMessage": true,
            "enableLogDetails": true,
            "sortOrder": "Descending"
          }
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
